  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sosType SosType @relation(fields: [sosTypeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sosTypeId])
  @@index([status])
}

// ==========================================
// Phase 14: Holiday Management Module
// ==========================================

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime @db.Date
  type        String   @default("Public") // Public, Company, Optional
  description String?  @db.Text
  status      String   @default("Active") // Active, Inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Branch multi-select stored as JSON array [1, 2, 5]
  branchIds Json? @default("[]")

  groups   HolidayInGroup[]
  requests OptionalHolidayRequest[]

  @@index([date])
  @@index([type])
}

model HolidayGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  holidays    HolidayInGroup[]
  assignments HolidayGroupAssignment[]
}

model HolidayInGroup {
  holidayId Int
  groupId   Int
  holiday   Holiday      @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  group     HolidayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([holidayId, groupId])
  @@index([holidayId])
  @@index([groupId])
}

model HolidayGroupAssignment {
  id           Int      @id @default(autoincrement())
  groupId      Int
  userId       Int?
  departmentId Int?
  createdAt    DateTime @default(now())

  group      HolidayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull) // Added relation to User needs to be reflected in User model too
  department Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([userId])
  @@index([departmentId])
}

model OptionalHolidayRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  holidayId Int
  status    String   @default("Pending") // Pending, Approved, Rejected
  remarks   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  holiday Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([holidayId])
  @@index([status])
}

// ==========================================
// Phase 15: Mobile Device Bind Module
// ==========================================

model MobileDevice {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  macAddress       String?
  deviceId         String?
  deviceName       String?
  deviceModel      String?
  osVersion        String?
  lastLoginAt      DateTime?
  status           String    @default("Unbound") // Bound, Unbound
  isActive         Boolean   @default(true) // For Toggle (Active/Inactive)
  isBindingEnabled Boolean   @default(true) // Whether strict binding is enforced for this user
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceChangeRequest {
  id            Int       @id @default(autoincrement())
  userId        Int
  oldDeviceId   String?
  oldDeviceName String?
  newDeviceId   String
  newDeviceName String?
  reason        String    @db.Text
  attachmentUrl String?
  status        String    @default("Pending") // Pending, Approved, Rejected
  adminRemarks  String?   @db.Text
  approvedById  Int?
  requestDate   DateTime  @default(now())
  resolvedAt    DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("DeviceRequestApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

// ==========================================
// Phase 14: Manage Chat Group Module
// ==========================================

model ChatGroup {
  id             Int     @id @default(autoincrement())
  name           String
  icon           String? @db.Text
  type           String  @default("Manual") // Auto Created, Manual
  visibilityType String  @default("Public") // Private, Public (for Manual groups)

  // Auto-Group Metadata
  isAutoCreated    Boolean @default(false)
  autoBranchId     Int?
  autoDepartmentId Int?
  autoZoneId       Int?
  autoLevelId      Int?

  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatGroupMember[]
  messages ChatMessage[]

  @@index([type])
  @@index([isAutoCreated])
}

model ChatGroupMember {
  id         Int     @id @default(autoincrement())
  groupId    Int
  userId     Int
  role       String  @default("Member") // Admin, Member
  visibility Boolean @default(true) // If true, user can see group
  status     String  @default("Active") // Active, Removed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model ChatMessage {
  id         Int     @id @default(autoincrement())
  groupId    Int
  senderId   Int
  message    String? @db.Text
  attachment String? @db.Text
  type       String  @default("Text") // Text, Image, File, System
  status     String  @default("Sent") // Sent, Delivered, Seen

  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([senderId])
}

// ==========================================
// Phase 16: Vendor Management Module
// ==========================================

model VendorCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active") // Active, Inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subCategories VendorSubCategory[]
  vendors       Vendor[]
}

model VendorSubCategory {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  status      String   @default("Active")
  categoryId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category VendorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vendors  Vendor[]

  @@unique([name, categoryId])
}

model Vendor {
  id            Int     @id @default(autoincrement())
  name          String
  categoryId    Int
  subCategoryId Int?
  contactPerson String?
  mobile        String
  email         String?

  // Business Details
  gstNumber   String?
  panNumber   String?
  companyName String?

  // Address Details
  country     String?
  state       String?
  city        String?
  area        String?
  pincode     String?
  fullAddress String? @db.Text

  // Financial Details
  bankName      String?
  accountNumber String?
  ifscCode      String?
  paymentTerms  Int? // Credit Days

  // Additional
  status        String  @default("Active")
  attachmentUrl String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    VendorCategory     @relation(fields: [categoryId], references: [id])
  subCategory VendorSubCategory? @relation(fields: [subCategoryId], references: [id])

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([city])
  @@index([status])
}

// ==========================================
// Phase 9: Background Verification (BGV) Module
// ==========================================

model VerificationType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active") // Active, Inactive
  added_by    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  verifications BackgroundVerification[]

  @@index([added_by])
}

model BackgroundVerification {
  id                   Int    @id @default(autoincrement())
  employee_id          Int
  branch_id            Int?
  department_id        Int?
  verification_type_id Int
  verification_way     String // Call, Email, Physical Visit, Document Verification

  // Status: Verified, Pending, Failed, Visit Not Started
  status String @default("Pending")

  verified_by       Int?
  verification_date DateTime?
  document_url      Json? // Array of document URLs
  remarks           String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee         User             @relation("VerificationEmployee", fields: [employee_id], references: [id], onDelete: Cascade)
  verifier         User?            @relation("VerificationVerifier", fields: [verified_by], references: [id], onDelete: SetNull)
  verificationType VerificationType @relation(fields: [verification_type_id], references: [id], onDelete: Cascade)
  branch           Branch?          @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  department       Department?      @relation(fields: [department_id], references: [id], onDelete: SetNull)

  @@index([employee_id])
  @@index([verification_type_id])
  @@index([status])
  @@index([branch_id])
  @@index([department_id])
}

// ==========================================
// Phase 10: Visitors Module
// ==========================================

model VisitorSubType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String // Interview, Delivery, Transport, Services, Others
  status    String   @default("Active") // Active, Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visitorLogs VisitorLog[]
}

model VisitorProfile {
  id             Int      @id @default(autoincrement())
  name           String
  mobile         String   @unique
  email          String?
  company        String?
  city           String?
  photo_url      String?
  is_blacklisted Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visitorLogs VisitorLog[]

  @@index([mobile])
}

model VisitorLog {
  id             Int       @id @default(autoincrement())
  visitor_id     Int
  sub_type_id    Int?
  employee_id    Int? // Employee whom to meet
  branch_id      Int?
  department_id  Int?
  purpose        String?   @db.Text
  in_time        DateTime  @default(now())
  out_time       DateTime?
  status         String    @default("Inside") // Inside, Checked-Out, Rejected, Cancelled
  otp_verified   Boolean   @default(false)
  vehicle_number String?
  added_by       Int? // Admin/Guard who checked-in

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visitor    VisitorProfile  @relation(fields: [visitor_id], references: [id], onDelete: Cascade)
  subType    VisitorSubType? @relation(fields: [sub_type_id], references: [id], onDelete: SetNull)
  employee   User?           @relation("EmployeeToMeet", fields: [employee_id], references: [id], onDelete: SetNull)
  branch     Branch?         @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  department Department?     @relation(fields: [department_id], references: [id], onDelete: SetNull)

  @@index([visitor_id])
  @@index([employee_id])
  @@index([status])
  @@index([in_time])
}

model VisitorSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  type      String   @default("String") // String, Number, Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ==========================================
// Phase 11: Complaints Module
// ==========================================

model ComplaintCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sla_limit Int // Resolution time in hours
  status    String   @default("Active") // Active, Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  complaints Complaint[]
}

model Complaint {
  id              Int       @id @default(autoincrement())
  complaint_no    String    @unique // CMP-YYYY-XXXX
  user_id         Int // Employee who raised it
  category_id     Int
  branch_id       Int?
  department_id   Int?
  title           String
  description     String    @db.Text
  priority        String    @default("Medium") // Low, Medium, High
  status          String    @default("Open") // Open, In Progress, Closed, Re-Open
  assigned_to     Int? // Admin/Manager ID
  rating          Int? // 1-5 feedback
  is_anonymous    Boolean   @default(false)
  last_updated_at DateTime? @updatedAt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                  @relation("ComplaintEmployee", fields: [user_id], references: [id], onDelete: Cascade)
  category    ComplaintCategory     @relation(fields: [category_id], references: [id], onDelete: Cascade)
  assignee    User?                 @relation("ComplaintAssignee", fields: [assigned_to], references: [id], onDelete: SetNull)
  branch      Branch?               @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  department  Department?           @relation(fields: [department_id], references: [id], onDelete: SetNull)
  comments    ComplaintComment[]
  attachments ComplaintAttachment[]

  @@index([user_id])
  @@index([category_id])
  @@index([status])
  @@index([createdAt])
}

model ComplaintComment {
  id           Int      @id @default(autoincrement())
  complaint_id Int
  user_id      Int
  comment      String   @db.Text
  is_internal  Boolean  @default(false)
  createdAt    DateTime @default(now())

  complaint Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([complaint_id])
}

model ComplaintAttachment {
  id           Int      @id @default(autoincrement())
  complaint_id Int
  file_url     String
  file_name    String
  createdAt    DateTime @default(now())

  complaint Complaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)

  @@index([complaint_id])
}

model ComplaintEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Discussion Forum Module
// ============================================================

model Discussion {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.LongText
  created_by  Int
  status      String   @default("Active") // Active, Closed, Deactivated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation("DiscussionCreatedBy", fields: [created_by], references: [id], onDelete: Cascade)

  targetsBranch DiscussionTargetBranch[]
  targetsDept   DiscussionTargetDept[]
  targetsUser   DiscussionTargetUser[]
  comments      DiscussionComment[]
  attachments   DiscussionAttachment[]
  reactions     DiscussionReaction[]

  @@index([created_by])
  @@index([status])
}

model DiscussionTargetBranch {
  id            Int @id @default(autoincrement())
  discussion_id Int
  branch_id     Int

  discussion Discussion @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@index([discussion_id])
  @@index([branch_id])
}

model DiscussionTargetDept {
  id            Int @id @default(autoincrement())
  discussion_id Int
  department_id Int

  discussion Discussion @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  department Department @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@index([discussion_id])
  @@index([department_id])
}

model DiscussionTargetUser {
  id            Int @id @default(autoincrement())
  discussion_id Int
  user_id       Int

  discussion Discussion @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  user       User       @relation("DiscussionTargetUsers", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([discussion_id])
  @@index([user_id])
}

model DiscussionComment {
  id            Int      @id @default(autoincrement())
  discussion_id Int
  user_id       Int
  parent_id     Int? // For threaded replies
  comment       String   @db.LongText
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  discussion  Discussion             @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      DiscussionComment?     @relation("ThreadedComments", fields: [parent_id], references: [id], onDelete: Cascade)
  replies     DiscussionComment[]    @relation("ThreadedComments")
  attachments DiscussionAttachment[]
  reactions   DiscussionReaction[]

  @@index([discussion_id])
  @@index([user_id])
  @@index([parent_id])
}

model DiscussionAttachment {
  id            Int     @id @default(autoincrement())
  file_url      String
  file_name     String
  file_type     String?
  discussion_id Int?
  comment_id    Int?

  discussion Discussion?        @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  comment    DiscussionComment? @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@index([discussion_id])
  @@index([comment_id])
}

model DiscussionReaction {
  id            Int    @id @default(autoincrement())
  discussion_id Int?
  comment_id    Int?
  user_id       Int
  reaction      String // Emoji or reaction type (e.g., 'like', 'love', 'insightful')

  discussion Discussion?        @relation(fields: [discussion_id], references: [id], onDelete: Cascade)
  comment    DiscussionComment? @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([discussion_id])
  @@index([comment_id])
  @@index([user_id])
}

// ==========================================
// Phase 12: Escalations Module
// ==========================================

model Escalation {
  id          Int       @id @default(autoincrement())
  title       String
  description String    @db.Text
  sender_id   Int
  receiver_id Int?
  branch_id   Int?
  priority    String    @default("Medium") // Urgent, High, Medium, Low
  status      String    @default("Open") // Open, In Progress, Closed
  category    String?
  reply_date  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sender   User    @relation("EscalationSender", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver User?   @relation("EscalationReceiver", fields: [receiver_id], references: [id], onDelete: SetNull)
  branch   Branch? @relation("EscalationBranch", fields: [branch_id], references: [id], onDelete: SetNull)

  attachments EscalationAttachment[]
  replies     EscalationReply[]

  @@index([sender_id])
  @@index([receiver_id])
  @@index([status])
  @@index([priority])
}

model EscalationAttachment {
  id            Int      @id @default(autoincrement())
  escalation_id Int
  file_url      String   @db.Text
  name          String
  file_type     String?
  createdAt     DateTime @default(now())

  escalation Escalation @relation(fields: [escalation_id], references: [id], onDelete: Cascade)

  @@index([escalation_id])
}

model EscalationReply {
  id            Int      @id @default(autoincrement())
  escalation_id Int
  user_id       Int
  message       String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  escalation Escalation @relation(fields: [escalation_id], references: [id], onDelete: Cascade)
  user       User       @relation("EscalationReplyUser", fields: [user_id], references: [id], onDelete: Cascade)

  attachments EscalationReplyAttachment[]

  @@index([escalation_id])
  @@index([user_id])
}

model EscalationReplyAttachment {
  id                  Int      @id @default(autoincrement())
  escalation_reply_id Int
  file_url            String   @db.Text
  name                String
  file_type           String?
  createdAt           DateTime @default(now())

  reply EscalationReply @relation(fields: [escalation_reply_id], references: [id], onDelete: Cascade)

  @@index([escalation_reply_id])
}

// ==========================================
// Phase 13: Meeting Module
// ==========================================

model Meeting {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?  @db.Text
  meeting_type    String   @default("Offline") // Online, Offline
  meeting_date    DateTime @db.Date
  start_time      String // HH:mm
  end_time        String // HH:mm
  organizer_id    Int
  location        String? // for offline
  meeting_link    String?  @db.Text // for online
  priority        String   @default("Medium") // Low, Medium, High
  status          String   @default("Scheduled") // Scheduled, Ongoing, Completed, Cancelled
  reminder_before Int?     @default(30) // minutes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizer    User                 @relation("MeetingOrganizer", fields: [organizer_id], references: [id])
  participants MeetingParticipant[]
  attachments  MeetingAttachment[]
  mom          MeetingMOM?
  actionItems  MeetingActionItem[]

  @@index([organizer_id])
  @@index([meeting_date])
  @@index([status])
}

model MeetingParticipant {
  id                Int       @id @default(autoincrement())
  meeting_id        Int
  user_id           Int
  attendance_status String    @default("Absent") // Present, Absent, Late
  join_time         DateTime?
  leave_time        DateTime?
  createdAt         DateTime  @default(now())

  meeting Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  user    User    @relation("MeetingParticipantUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([meeting_id, user_id])
  @@index([meeting_id])
  @@index([user_id])
}

model MeetingMOM {
  id                Int      @id @default(autoincrement())
  meeting_id        Int      @unique
  discussion_points String?  @db.LongText
  decisions         String?  @db.LongText
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  meeting Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)

  @@index([meeting_id])
}

model MeetingActionItem {
  id          Int       @id @default(autoincrement())
  meeting_id  Int
  assigned_to Int
  description String    @db.Text
  deadline    DateTime? @db.Date
  status      String    @default("Pending") // Pending, In Progress, Completed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  meeting  Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  assignee User    @relation("MeetingActionAssignee", fields: [assigned_to], references: [id], onDelete: Cascade)

  @@index([meeting_id])
  @@index([assigned_to])
  @@index([status])
}

model MeetingAttachment {
  id         Int      @id @default(autoincrement())
  meeting_id Int
  file_url   String   @db.Text
  name       String
  file_type  String?
  createdAt  DateTime @default(now())

  meeting Meeting @relation(fields: [meeting_id], references: [id], onDelete: Cascade)

  @@index([meeting_id])
}

model MeetingSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
