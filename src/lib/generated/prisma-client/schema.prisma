// ==========================================
// Phase 12: Idea Box Module
// ==========================================

model IdeaCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active") // Active, Inactive
  created_by  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User?  @relation("IdeaCategoryCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  ideas   Idea[]

  @@index([created_by])
}

model Idea {
  id                 Int       @id @default(autoincrement())
  title              String
  categoryId         Int
  userId             Int
  description        String    @db.Text
  attachmentUrl      String?
  expectedBenefit    String?   @db.Text // Cost saving, Time saving, Revenue growth, etc.
  status             String    @default("Pending") // Pending, Under Review, Approved, Rejected, Implemented
  approvalRemarks    String?   @db.Text
  isAnonymous        Boolean   @default(false)
  rewardPoints       Int       @default(0)
  implementationDate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  category IdeaCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
