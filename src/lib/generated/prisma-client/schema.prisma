  votes    IdeaVote[]
  comments IdeaComment[]
  rewards  IdeaReward[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
}

model IdeaVote {
  id        Int      @id @default(autoincrement())
  ideaId    Int
  userId    Int
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
}

model IdeaComment {
  id        Int      @id @default(autoincrement())
  ideaId    Int
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IdeaReward {
  id          Int      @id @default(autoincrement())
  ideaId      Int
  userId      Int
  points      Int
  description String?  @db.Text
  createdAt   DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation("IdeaRewardReceivedBy", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ideaId])
}

// ==========================================
// Phase 13: SOS Management Module
// ==========================================

model SosType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  imageUrl        String?  @db.Text
  validityMinutes Int      @default(60)
  status          String   @default("Active") // Active, Inactive
  isPredefined    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  alerts SosAlert[]
}

model SosAlert {
  id         Int       @id @default(autoincrement())
  userId     Int
  sosTypeId  Int
  message    String?   @db.Text
  imageUrl   String?   @db.Text // Proof photo
