# ============================================================
# MineHR-HRMS — Environment Variables Reference
# Copy this file to .env.local (root) or backend/.env
# NEVER commit actual secrets to git!
# ============================================================

# --- Backend (backend/.env) ---

# TiDB Cloud MySQL connection string (production)
DATABASE_URL="mysql://<user>:<password>@<host>:4000/<database>?sslaccept=strict&connection_limit=5&pool_timeout=30"

# JWT signing secret — keep this long and random
JWT_SECRET="your_jwt_secret_here"

# Server port (local dev only — Vercel ignores this)
PORT=5001

# --- Vercel Environment Variables ---
# Set these in the Vercel Dashboard → Project → Settings → Environment Variables:
# DATABASE_URL     → your TiDB Cloud connection string
# JWT_SECRET       → your JWT secret
# NODE_ENV         → production
