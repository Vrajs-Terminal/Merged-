  @@index([createdById], map: "VehicleCategory_createdById_fkey")
}

model EmployeeVehicle {
  id             Int             @id @default(autoincrement())
  vehicle_name   String
  vehicle_number String          @unique
  vehicle_value  Float?          @default(0)
  image_url_1    String?         @db.Text
  image_url_2    String?         @db.Text
  image_url_3    String?         @db.Text
  status         String          @default("Active")
  assigned_date  DateTime        @default(now())
  userId         Int
  categoryId     Int
  branchId       Int?
  departmentId   Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  branch         Branch?         @relation("VehicleBranch", fields: [branchId], references: [id])
  category       VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  department     Department?     @relation("VehicleDepartment", fields: [departmentId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([categoryId])
  @@index([branchId])
  @@index([departmentId], map: "EmployeeVehicle_departmentId_fkey")
}

model IdeaCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active")
  created_by  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ideas       Idea[]
  creator     User?    @relation("IdeaCategoryCreatedBy", fields: [created_by], references: [id])

  @@index([created_by])
}

model Idea {
  id                 Int           @id @default(autoincrement())
  title              String
  categoryId         Int
  userId             Int
  description        String        @db.Text
  attachmentUrl      String?
  expectedBenefit    String?       @db.Text
  status             String        @default("Pending")
  approvalRemarks    String?       @db.Text
  isAnonymous        Boolean       @default(false)
  rewardPoints       Int           @default(0)
  implementationDate DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  category           IdeaCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user               User          @relation("IdeaSubmittedBy", fields: [userId], references: [id], onDelete: Cascade)
  comments           IdeaComment[]
  rewards            IdeaReward[]
  votes              IdeaVote[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
}

model IdeaVote {
  id        Int      @id @default(autoincrement())
  ideaId    Int
  userId    Int
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@index([userId], map: "IdeaVote_userId_fkey")
}

model IdeaComment {
  id        Int      @id @default(autoincrement())
  ideaId    Int
  userId    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaId], map: "IdeaComment_ideaId_fkey")
  @@index([userId], map: "IdeaComment_userId_fkey")
}

model IdeaReward {
  id          Int      @id @default(autoincrement())
  ideaId      Int
  userId      Int
  points      Int
  description String?  @db.Text
  createdAt   DateTime @default(now())
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user        User     @relation("IdeaRewardReceivedBy", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ideaId])
}

model SosType {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  imageUrl        String?    @db.Text
  validityMinutes Int        @default(60)
  status          String     @default("Active")
  isPredefined    Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  alerts          SosAlert[]
}

model SosAlert {
  id         Int       @id @default(autoincrement())
  userId     Int
  sosTypeId  Int
  message    String?   @db.Text
  imageUrl   String?   @db.Text
  latitude   Float?
  longitude  Float?
  status     String    @default("Active")
  resolvedAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sosType    SosType   @relation(fields: [sosTypeId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sosTypeId])
  @@index([status])
}

model ChatGroup {
  id               Int               @id @default(autoincrement())
  name             String
  icon             String?           @db.Text
  type             String            @default("Manual")
  visibilityType   String            @default("Public")
  isAutoCreated    Boolean           @default(false)
  autoBranchId     Int?
  autoDepartmentId Int?
  autoZoneId       Int?
  autoLevelId      Int?
  status           String            @default("Active")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          ChatGroupMember[]
  messages         ChatMessage[]

  @@index([type])
  @@index([isAutoCreated])
}

model ChatGroupMember {
  id         Int       @id @default(autoincrement())
  groupId    Int
  userId     Int
  role       String    @default("Member")
  visibility Boolean   @default(true)
  status     String    @default("Active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  group      ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model ChatMessage {
  id         Int       @id @default(autoincrement())
  groupId    Int
  senderId   Int
  message    String?   @db.Text
  attachment String?   @db.Text
  type       String    @default("Text")
  status     String    @default("Sent")
  isPinned   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  group      ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender     User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([senderId])
}

model Holiday {
  id         Int                      @id @default(autoincrement())
  name       String
  date       DateTime                 @db.Date
  type       String                   @default("Public")
  status     String                   @default("Active")
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  groupId    Int?
  visibility String                   @default("All")
  group      HolidayGroup?            @relation(fields: [groupId], references: [id])
  requests   OptionalHolidayRequest[]

  @@index([groupId], map: "Holiday_groupId_fkey")
}

model HolidayGroup {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  description String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  status      String               @default("Active")
  holidays    Holiday[]
  assignments HolidayGroupAssign[]
}

model HolidayGroupAssign {
  id           Int          @id @default(autoincrement())
  groupId      Int
  userId       Int?
  branchId     Int?
  departmentId Int?
  createdAt    DateTime     @default(now())
  group        HolidayGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId], map: "HolidayGroupAssign_groupId_fkey")
}

model OptionalHolidayRequest {
  id           Int      @id @default(autoincrement())
  userId       Int
  holidayId    Int
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  adminRemarks String?
  reason       String?  @db.Text
  holiday      Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([holidayId])
  @@index([userId])
}

model MobileDevice {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  deviceId    String?  @unique
  deviceName  String?
  osVersion   String?
  status      String   @default("Bound")
  isActive    Boolean  @default(true)
  macAddress  String?
  deviceModel String?
  appVersion  String?
  boundAt     DateTime @default(now())
  lastActive  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceChangeRequest {
  id            Int       @id @default(autoincrement())
  userId        Int
  oldDeviceId   String?
  reason        String    @db.Text
  status        String    @default("Pending")
  resolvedAt    DateTime?
  approvedById  Int?
  newDeviceId   String?
  newDeviceName String?
  oldDeviceName String?
  requestedAt   DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([approvedById], map: "DeviceChangeRequest_approvedById_fkey")
  @@index([userId])
}

model VendorCategory {
  id            Int                 @id @default(autoincrement())
  name          String              @unique
  description   String?             @db.Text
  status        String              @default("Active")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  vendors       Vendor[]
  subCategories VendorSubCategory[]
}

model VendorSubCategory {
  id          Int            @id @default(autoincrement())
  name        String
  description String?        @db.Text
  status      String         @default("Active")
  categoryId  Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vendors     Vendor[]
  category    VendorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId])
  @@index([categoryId], map: "VendorSubCategory_categoryId_fkey")
}

model Vendor {
  id            Int                @id @default(autoincrement())
  name          String
  categoryId    Int
  subCategoryId Int?
  contactPerson String?
  mobile        String
  email         String?
  gstNumber     String?
  panNumber     String?
  companyName   String?
  country       String?
  state         String?
  city          String?
  area          String?
  pincode       String?
  fullAddress   String?            @db.Text
  bankName      String?
  accountNumber String?
  ifscCode      String?
  paymentTerms  Int?
  status        String             @default("Active")
  attachmentUrl String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  category      VendorCategory     @relation(fields: [categoryId], references: [id])
  subCategory   VendorSubCategory? @relation(fields: [subCategoryId], references: [id])

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([city])
  @@index([status])
}

model Escalation {
  id          Int                    @id @default(autoincrement())
  title       String
  description String                 @db.Text
  sender_id   Int
  receiver_id Int?
  branch_id   Int?
  status      String                 @default("Open")
  priority    String                 @default("Medium")
  category    String?
  reply_date  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  branch      Branch?                @relation(fields: [branch_id], references: [id])
  receiver    User?                  @relation("EscalationReceiver", fields: [receiver_id], references: [id])
  sender      User                   @relation("EscalationSender", fields: [sender_id], references: [id])
  attachments EscalationAttachment[]
  replies     EscalationReply[]

  @@index([sender_id])
  @@index([receiver_id])
  @@index([status])
  @@index([branch_id], map: "Escalation_branch_id_fkey")
}

model EscalationReply {
  id            Int                    @id @default(autoincrement())
  escalation_id Int
  user_id       Int
  message       String                 @db.Text
  createdAt     DateTime               @default(now())
  attachments   EscalationAttachment[]
  escalation    Escalation             @relation(fields: [escalation_id], references: [id], onDelete: Cascade)
  user          User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([escalation_id], map: "EscalationReply_escalation_id_fkey")
  @@index([user_id], map: "EscalationReply_user_id_fkey")
}

model EscalationAttachment {
  id            Int              @id @default(autoincrement())
  escalation_id Int?
  reply_id      Int?
  file_url      String
  name          String
  file_type     String
  escalation    Escalation?      @relation(fields: [escalation_id], references: [id], onDelete: Cascade)
  reply         EscalationReply? @relation(fields: [reply_id], references: [id], onDelete: Cascade)

  @@index([escalation_id], map: "EscalationAttachment_escalation_id_fkey")
  @@index([reply_id], map: "EscalationAttachment_reply_id_fkey")
}
